# Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use — selected via the Settings page in the UI.
# Example values: models/gemini-2.5-flash, models/gemini-2.0-flash, models/gemini-1.5-pro
GEMINI_MODEL=models/gemini-2.5-flash
